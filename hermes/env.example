# Home Steward — Hermes Environment Variables
# Copy this file to ~/.hermes/.env and fill in your values.
# NEVER commit the real .env file!

# --- Hermes API Server ---
API_SERVER_ENABLED=true
API_SERVER_KEY=change-me-to-a-random-secret

# --- Model Provider API Keys (uncomment the one you use) ---
# OLLAMA requires no key (local)
# NOUS_PORTAL_API_KEY=sk-xxx
# OPENROUTER_API_KEY=sk-xxx

# --- Home Assistant ---
HA_MCP_URL=http://homeassistant.local:8123/api/mcp
HA_TOKEN=your-long-lived-access-token-here

# --- ESP RainMaker (optional) ---
# RAINMAKER_EMAIL=your@email.com
# RAINMAKER_PASSWORD=your-password

# --- Render Adapter ---
RENDER_ADAPTER_HOST=127.0.0.1
RENDER_ADAPTER_PORT=8700
HERMES_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-to-a-random-secret
